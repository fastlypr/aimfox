# Copy to `.env` and fill in, then run:  node --env-file=.env app.js

# Aimfox API key (Vipan workspace): Aimfox → Workspace Settings → Integrations
AIMFOX_API_KEY=

# Telegram bot token (@BotFather → /newbot)
TELEGRAM_BOT_TOKEN=

# Telegram chat id (@userinfobot), or a group id
TELEGRAM_CHAT_ID=

# --- webhook (instant path) ---
PORT=3000
WEBHOOK_PATH=/aimfox-reply
# Random string; Aimfox sends it as the x-webhook-secret header. Generate: openssl rand -hex 16
AIMFOX_WEBHOOK_SECRET=

# --- backup poll (safety net for dropped webhooks) ---
BACKUP_POLL_SECONDS=600
