# Copy this file to `.env` and fill in the values, then run:  node --env-file=.env server.js

# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From @userinfobot (your numeric id, or a group id)
TELEGRAM_CHAT_ID=123456789

# Port the local server listens on (default 3000)
PORT=3000

# Path Aimfox posts to (default /aimfox-reply). Keep it in sync with the registered webhook.
WEBHOOK_PATH=/aimfox-reply

# Optional: a random string. If set, the Aimfox webhook must send it as the
# `x-webhook-secret` header, so only Aimfox can trigger your relay.
AIMFOX_WEBHOOK_SECRET=
