# Copy this file to `.env` and fill in, then run:  node --env-file=.env poller.js

# Aimfox API key for the Vipan workspace.
# Create it in Aimfox: Workspace Settings → Integrations → API key.
AIMFOX_API_KEY=

# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=

# From @userinfobot (your numeric id, or a group id)
TELEGRAM_CHAT_ID=

# How often to check for new replies, in seconds (default 120 = every 2 min)
POLL_INTERVAL_SECONDS=120
